# ====== Core ======
ENV=production
DEBUG=false
LOG_LEVEL=INFO
PROJECT_NAME=VulnInt
API_V1_PREFIX=/api/v1
TZ=UTC

# ====== Postgres ======
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=vulnint
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=vulnint
DATABASE_URL=postgresql+asyncpg://vulnint:change_me_strong_password@postgres:5432/vulnint
SYNC_DATABASE_URL=postgresql+psycopg2://vulnint:change_me_strong_password@postgres:5432/vulnint

# ====== Redis ======
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0
CELERY_BROKER_URL=redis://:change_me_redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change_me_redis_password@redis:6379/2

# ====== OpenSearch ======
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false

# ====== Auth ======
JWT_SECRET=change_me_to_a_long_random_string_min_64_chars_use_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_HASH_ROUNDS=12
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMeImmediately!1

# ====== CORS ======
CORS_ORIGINS=["http://localhost:3000","https://vulnint.example.com"]

# ====== Rate Limiting ======
RATE_LIMIT_PER_MINUTE=120

# ====== External Feeds ======
NVD_API_KEY=
NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
MITRE_CVE_FEED=https://cve.mitre.org/data/downloads/allitems.csv.gz
UBUNTU_USN_FEED=https://ubuntu.com/security/notices.json
DEBIAN_DSA_FEED=https://security-tracker.debian.org/tracker/data/json
ALMALINUX_ERRATA_FEED=https://errata.almalinux.org/feed/errata-rss.xml
ROCKY_ERRATA_FEED=https://errata.rockylinux.org/api/v2/advisories
CLOUDLINUX_FEED=https://cloudlinux.com/security-advisories/feed
MSRC_FEED=https://api.msrc.microsoft.com/cvrf/v3.0/updates
CPANEL_FEED=https://news.cpanel.com/category/security/feed/
CISA_KEV_FEED=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
EXPLOITDB_FEED=https://gitlab.com/exploit-database/exploitdb/-/raw/main/files_exploits.csv

# ====== Alerting ======
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=alerts@example.com
SMTP_TLS=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
SIEM_WEBHOOK_URL=

ALERT_SEVERITY_THRESHOLD=high
ALERT_KEV_ALWAYS=true

# ====== Frontend ======
NEXT_PUBLIC_API_URL=https://vulnint.example.com/api/v1
