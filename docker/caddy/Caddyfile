# VulnInt — Caddy reverse proxy with automatic TLS
#
# Caddy automatically provisions and renews Let's Encrypt certificates.
# No certbot, no cron jobs, no manual TLS configuration needed.
#
# Rate limiting is handled at the API level by FastAPI's slowapi middleware
# (see RATE_LIMIT_PER_MINUTE in .env). Caddy focuses on TLS + proxying.
#
# Reference: https://caddyserver.com/docs/caddyfile

vulnint.example.com {

    # ── Security headers (applied to every response) ──────────────────────
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    }

    # ── Health probe (used by docker-compose healthcheck) ─────────────────
    handle /healthz {
        respond "ok" 200
    }

    # ── Auth endpoints ────────────────────────────────────────────────────
    handle /api/v1/auth/login {
        reverse_proxy api:8000 {
            header_up Host {host}
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── Agent inventory ingest — larger body, longer timeout ──────────────
    handle /api/v1/inventory {
        request_body {
            max_size 8MB
        }
        reverse_proxy api:8000 {
            header_up Host {host}
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
            transport http {
                read_timeout 120s
            }
        }
    }

    # ── Agent download endpoints (public) ─────────────────────────────────
    handle /api/v1/agents/* {
        reverse_proxy api:8000 {
            header_up Host {host}
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── All other API calls ───────────────────────────────────────────────
    handle /api/* {
        reverse_proxy api:8000 {
            header_up Host {host}
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }

    # ── API docs ──────────────────────────────────────────────────────────
    handle /docs* {
        reverse_proxy api:8000
    }
    handle /redoc* {
        reverse_proxy api:8000
    }
    handle /openapi.json* {
        reverse_proxy api:8000
    }

    # ── Health / readiness probes ─────────────────────────────────────────
    handle /health* {
        reverse_proxy api:8000
    }
    handle /ready* {
        reverse_proxy api:8000
    }

    # ── Frontend (Next.js) ────────────────────────────────────────────────
    handle {
        reverse_proxy frontend:3000 {
            header_up Host {host}
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote_host}
        }
    }
}
