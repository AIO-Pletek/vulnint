<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>VulnInt Alert: {{ cve_id }}</title>
</head>
<body style="margin:0;padding:0;background:#0b0d12;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#e6e8ee;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#0b0d12;padding:24px 0;">
    <tr><td align="center">
      <table role="presentation" width="640" cellpadding="0" cellspacing="0" style="max-width:640px;background:#11141b;border:1px solid #1f242f;border-radius:12px;overflow:hidden;">
        <tr>
          <td style="padding:20px 24px;background:linear-gradient(135deg,#1a1f2b 0%,#11141b 100%);border-bottom:1px solid #1f242f;">
            <table width="100%" role="presentation"><tr>
              <td style="font-size:13px;letter-spacing:.12em;color:#7c8aa3;text-transform:uppercase;">VulnInt &middot; Security Alert</td>
              <td align="right" style="font-size:12px;color:#7c8aa3;">{{ generated_at }}</td>
            </tr></table>
          </td>
        </tr>
        <tr>
          <td style="padding:28px 24px 8px 24px;">
            <div style="display:inline-block;padding:6px 12px;border-radius:999px;font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
                        background:{{ severity_bg }};color:{{ severity_fg }};">
              {{ severity|upper }}{% if cvss %} &middot; CVSS {{ "%.1f"|format(cvss) }}{% endif %}{% if kev %} &middot; CISA KEV{% endif %}
            </div>
            <h1 style="margin:14px 0 4px 0;font-size:22px;line-height:1.3;color:#ffffff;">{{ cve_id }}</h1>
            <div style="font-size:14px;color:#9aa6bd;">{{ title or "Vulnerability detected on managed inventory" }}</div>
          </td>
        </tr>

        <tr>
          <td style="padding:8px 24px 0 24px;">
            <p style="margin:12px 0;font-size:14px;line-height:1.6;color:#c8d0e0;">
              {{ summary or "A vulnerability matching your alert rule has been correlated against your managed servers." }}
            </p>
          </td>
        </tr>

        {% if affected_servers %}
        <tr>
          <td style="padding:8px 24px;">
            <h3 style="margin:18px 0 8px 0;font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:#7c8aa3;">Affected Servers ({{ affected_servers|length }})</h3>
            <table width="100%" role="presentation" cellpadding="0" cellspacing="0"
                   style="border-collapse:separate;border-spacing:0;border:1px solid #1f242f;border-radius:8px;overflow:hidden;">
              <thead>
                <tr style="background:#161a23;">
                  <th align="left" style="padding:10px 12px;font-size:12px;color:#7c8aa3;border-bottom:1px solid #1f242f;">Hostname</th>
                  <th align="left" style="padding:10px 12px;font-size:12px;color:#7c8aa3;border-bottom:1px solid #1f242f;">OS</th>
                  <th align="left" style="padding:10px 12px;font-size:12px;color:#7c8aa3;border-bottom:1px solid #1f242f;">Package</th>
                  <th align="left" style="padding:10px 12px;font-size:12px;color:#7c8aa3;border-bottom:1px solid #1f242f;">Installed</th>
                  <th align="left" style="padding:10px 12px;font-size:12px;color:#7c8aa3;border-bottom:1px solid #1f242f;">Fixed</th>
                </tr>
              </thead>
              <tbody>
                {% for s in affected_servers %}
                <tr>
                  <td style="padding:10px 12px;font-size:13px;color:#e6e8ee;border-bottom:1px solid #1f242f;">{{ s.hostname }}</td>
                  <td style="padding:10px 12px;font-size:13px;color:#9aa6bd;border-bottom:1px solid #1f242f;">{{ s.os_family }} {{ s.os_version or "" }}</td>
                  <td style="padding:10px 12px;font-size:13px;color:#e6e8ee;border-bottom:1px solid #1f242f;font-family:ui-monospace,Menlo,Consolas,monospace;">{{ s.package }}</td>
                  <td style="padding:10px 12px;font-size:13px;color:#f3a26b;border-bottom:1px solid #1f242f;font-family:ui-monospace,Menlo,Consolas,monospace;">{{ s.installed_version }}</td>
                  <td style="padding:10px 12px;font-size:13px;color:#7ee08a;border-bottom:1px solid #1f242f;font-family:ui-monospace,Menlo,Consolas,monospace;">{{ s.fixed_version or "—" }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </td>
        </tr>
        {% endif %}

        {% if remediation %}
        <tr>
          <td style="padding:8px 24px;">
            <h3 style="margin:18px 0 8px 0;font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:#7c8aa3;">Remediation</h3>
            <div style="background:#0e1219;border:1px solid #1f242f;border-radius:8px;padding:14px;font-size:13px;line-height:1.6;color:#c8d0e0;font-family:ui-monospace,Menlo,Consolas,monospace;white-space:pre-wrap;">{{ remediation }}</div>
          </td>
        </tr>
        {% endif %}

        {% if references %}
        <tr>
          <td style="padding:8px 24px 16px 24px;">
            <h3 style="margin:18px 0 8px 0;font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:#7c8aa3;">References</h3>
            <ul style="margin:0;padding-left:18px;color:#9aa6bd;font-size:13px;line-height:1.7;">
              {% for r in references[:8] %}<li><a href="{{ r }}" style="color:#7aa7ff;text-decoration:none;">{{ r }}</a></li>{% endfor %}
            </ul>
          </td>
        </tr>
        {% endif %}

        <tr>
          <td style="padding:18px 24px;background:#0e1219;border-top:1px solid #1f242f;">
            <a href="{{ dashboard_url }}" style="display:inline-block;background:#3b82f6;color:#ffffff;text-decoration:none;font-weight:600;font-size:13px;padding:10px 16px;border-radius:8px;">Open in VulnInt Dashboard →</a>
          </td>
        </tr>
        <tr>
          <td style="padding:14px 24px;font-size:11px;color:#5b677e;">
            Sent by VulnInt Vulnerability Intelligence Platform. This is an automated message.
          </td>
        </tr>
      </table>
    </td></tr>
  </table>
</body>
</html>
