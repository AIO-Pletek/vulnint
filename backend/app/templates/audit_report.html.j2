<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>VulnInt Audit Report — {{ hostname }}</title>
<style>
  :root {
    --bg: #0b0d12; --card: #11141b; --border: #1f242f;
    --text: #e6e8ee; --muted: #7c8aa3; --subtle: #9aa6bd;
    --critical: #eb5a5a; --high: #f3a26b; --medium: #f0c05a; --low: #6fa8f0; --none: #7c8aa3;
    --blue: #3b82f6; --green: #7ee08a;
    --radius: 8px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    background: var(--bg); color: var(--text);
  }
  body { margin: 0; padding: 24px; }
  .container { max-width: 800px; margin: 0 auto; }
  .no-print { }
  .header { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px 24px; margin-bottom: 20px; }
  .header h1 { margin: 0 0 4px 0; font-size: 20px; }
  .header .meta-row { display: flex; gap: 24px; flex-wrap: wrap; margin-top: 10px; font-size: 13px; color: var(--muted); }
  .header .env-badge { display: inline-block; padding: 2px 10px; border-radius: 999px; font-size: 11px; font-weight: 700; text-transform: uppercase; background: #1f242f; }
  .header .env-badge.production { background: rgba(235,90,90,.15); color: var(--critical); }
  .summary { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; }
  .summary-chip { padding: 6px 14px; border-radius: var(--radius); font-size: 13px; font-weight: 600; border: 1px solid var(--border); background: var(--card); }
  .summary-chip.crit { border-color: rgba(235,90,90,.3); color: var(--critical); }
  .summary-chip.high { border-color: rgba(243,162,107,.3); color: var(--high); }
  .summary-chip.med  { border-color: rgba(240,192,90,.3); color: var(--medium); }
  .summary-chip.low  { border-color: rgba(111,168,240,.3); color: var(--low); }
  .section { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 16px; overflow: hidden; }
  .section-title { padding: 12px 16px; font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); background: #0e1219; border-bottom: 1px solid var(--border); font-weight: 700; }
  .finding { padding: 14px 16px; border-bottom: 1px solid var(--border); }
  .finding:last-child { border-bottom: 0; }
  .finding-row { display: flex; align-items: flex-start; gap: 10px; }
  .sev { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 10px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; white-space: nowrap; }
  .sev.critical { background: rgba(235,90,90,.15); color: var(--critical); }
  .sev.high     { background: rgba(243,162,107,.15); color: var(--high); }
  .sev.medium   { background: rgba(240,192,90,.15); color: var(--medium); }
  .sev.low      { background: rgba(111,168,240,.15); color: var(--low); }
  .finding-title { font-size: 14px; font-weight: 600; margin: 0 0 3px 0; }
  .finding-desc { font-size: 13px; color: var(--subtle); line-height: 1.5; margin: 0 0 6px 0; }
  .remediation { background: #0e1219; border-radius: var(--radius); padding: 10px 14px; font-size: 12px; color: var(--green); font-family: ui-monospace, Menlo, Consolas, monospace; }
  .status-tag { font-size: 11px; padding: 2px 8px; border-radius: 4px; border: 1px solid var(--border); color: var(--muted); }
  .footer { text-align: center; font-size: 11px; color: #5b677e; padding: 16px 0; }
  .btn-print { display: inline-block; background: var(--blue); color: #fff; padding: 8px 16px; border-radius: 6px; text-decoration: none; font-size: 13px; font-weight: 600; cursor: pointer; border: none; }
  @media print {
    .no-print { display: none !important; }
    body { background: #fff; color: #111; padding: 0; }
    :root { --bg: #fff; --card: #fff; --border: #ccc; --text: #111; --muted: #555; --subtle: #444; }
    .container { max-width: 100%; }
    .header, .section, .summary-chip { border: 1px solid #ccc; background: #fff; }
    .section-title { background: #f5f5f5; color: #333; }
    .remediation { background: #f0f0f0; color: #166534; }
  }
</style>
</head>
<body>
<div class="container">

  <!-- Print / Download bar -->
  <div class="no-print" style="display:flex;gap:10px;justify-content:flex-end;margin-bottom:12px;">
    <button class="btn-print" onclick="window.print()">🖨️ Save as PDF / Print</button>
  </div>

  <!-- Header -->
  <div class="header">
    <h1>🛡️ Security Audit Report</h1>
    <div style="font-size:18px;font-weight:700;margin-top:8px;">{{ hostname }}</div>
    <div class="meta-row">
      <span>{{ os_family|upper }} {{ os_version or "" }} &middot; {{ kernel or "—" }}</span>
      {% if ip_address %}<span>IP: {{ ip_address }}</span>{% endif %}
      <span class="env-badge {{ environment }}">{{ environment }}</span>
      <span>{{ generated_at }}</span>
    </div>
  </div>

  <!-- Summary -->
  {% set sevs = [('critical', 'crit', '🔴'), ('high', 'high', '🟠'), ('medium', 'med', '🟡'), ('low', 'low', '🔵')] %}
  {% if summary %}
  <div class="summary">
    {% for key, cls, icon in sevs %}
    {% if summary.get(key, 0) > 0 %}
    <div class="summary-chip {{ cls }}">{{ icon }} {{ summary[key] }} {{ key|capitalize }}</div>
    {% endif %}
    {% endfor %}
  </div>
  {% endif %}

  <!-- Categories -->
  {% set cat_labels = {"ssh": "SSH Configuration", "firewall": "Firewall & Network", "updates": "System Updates", "services": "Services & Ports", "misc": "System Hardening"} %}

  {% for cat in categories %}
  {% if cat.findings and cat.findings|length > 0 %}
  <div class="section">
    <div class="section-title">
      {{ cat_labels.get(cat.name, cat.name) }}
      <span style="font-weight:400;text-transform:none;letter-spacing:0;"> — {{ cat.findings|length }} finding{% if cat.findings|length != 1 %}s{% endif %}</span>
    </div>
    {% for f in cat.findings %}
    <div class="finding">
      <div class="finding-row">
        <span class="sev {{ f.severity }}">{{ f.severity }}</span>
        <div style="flex:1;min-width:0;">
          <div class="finding-title">{{ f.title }}</div>
          <p class="finding-desc">{{ f.description }}</p>
          {% if f.remediation %}
          <div class="remediation">💡 {{ f.remediation }}</div>
          {% endif %}
        </div>
        <span class="status-tag">{{ f.status }}</span>
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}
  {% endfor %}

  {% if total == 0 %}
  <div class="section">
    <div style="padding:20px;text-align:center;color:var(--green);font-size:15px;font-weight:600;">
      ✅ No security issues found. System looks well-configured.
    </div>
  </div>
  {% endif %}

  <div class="footer">
    Generated by VulnInt Vulnerability Intelligence Platform &middot; {{ generated_at }}<br>
    <span style="font-size:10px;">{{ total }} total finding{% if total != 1 %}s{% endif %}</span>
  </div>

</div>
</body>
</html>
